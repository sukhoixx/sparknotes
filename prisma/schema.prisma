generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// id = User.id (NextAuth CUID). Old device-UUID rows become unreachable but don't conflict.
model UserProfile {
  id              String   @id
  screenName      String   @unique @db.VarChar(50)
  categories      Json
  lang            String?  @default("en") @db.VarChar(10)
  streak          Int      @default(0)
  streakUpdatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// One row per user per article per day — deduplicates repeated opens
model ReadingSession {
  id        Int      @id @default(autoincrement())
  userId    String
  postId    Int
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([userId, postId, date])
}

// Computed daily totals for rewards display
model DailyReward {
  userId       String
  date         DateTime @db.Date
  articlesRead Int      @default(0)
  pointsEarned Float    @default(0)
  multiplier   Float    @default(1)
  badge        String?  @db.VarChar(20)

  @@id([userId, date])
}

model Comment {
  id         Int      @id @default(autoincrement())
  postId     Int
  text       String   @db.VarChar(500)
  screenName String   @db.VarChar(50) @default("Anonymous")
  createdAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(500)
  snippet     String   @db.VarChar(1000)
  body        String   @db.Text
  funFact     String   @db.Text
  tags        Json
  category    String
  emoji       String
  gradient    String
  badge       String
  authorEmoji String
  authorBg    String
  categories  Json     @default("[]")
  sourceUrl   String?  @db.Text
  imageUrl    String?  @db.Text
  zhTitle     String?  @db.VarChar(500)
  zhSnippet   String?  @db.VarChar(1000)
  zhBody      String?  @db.Text
  zhFunFact   String?  @db.Text
  zhTitleCn   String?  @db.VarChar(500)
  zhSnippetCn String?  @db.VarChar(1000)
  zhBodyCn    String?  @db.Text
  zhFunFactCn String?  @db.Text
  views       Int      @default(0)
  eventSlug   String?  @db.VarChar(100)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  comments Comment[]
  likedBy  Like[]
}

// Singleton row (id=1) — upserted by the event detector
model ActiveEvent {
  id          Int      @id @default(1)
  slug        String   @db.VarChar(100)
  label       String   @db.VarChar(200)
  labelZh     String?  @db.VarChar(200)
  description String?  @db.VarChar(500)
  query       String   @db.VarChar(300)
  score       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Like {
  userId String
  postId Int
  emoji  String @default("❤️") @db.VarChar(10)
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Activity {
  userId String
  date   DateTime @db.Date

  @@id([userId, date])
}

model DailyViews {
  date  DateTime @id @db.Date
  count Int      @default(0)
}

model DeviceToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(500)
  platform  String   @db.VarChar(10)
  lang      String   @default("en") @db.VarChar(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushLog {
  id        Int      @id @default(autoincrement())
  postId    Int
  title     String   @db.VarChar(500)
  topics    String?  @db.VarChar(500)
  sentAt    DateTime @default(now())
}
